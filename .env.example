# VPN 服务器配置 - 复制为 .env 并填入真实值
# cp .env.example .env

# ===== 服务器信息 =====
SERVER_IP=你的服务器IP
SSH_USER=linuxuser
SSH_PORT=22

# ===== 主节点 Reality (端口2083) =====
MAIN_UUID=你的UUID
MAIN_PORT=2083
MAIN_DEST=www.microsoft.com
MAIN_PRIVATE_KEY=你的私钥
MAIN_PUBLIC_KEY=你的公钥
MAIN_SHORT_ID=你的shortid

# ===== 备用节点 Reality (端口8443) =====
BACKUP_UUID=你的UUID
BACKUP_PORT=8443
BACKUP_DEST=addons.mozilla.org
BACKUP_PRIVATE_KEY=你的私钥
BACKUP_PUBLIC_KEY=你的公钥
BACKUP_SHORT_ID=你的shortid

# ===== CDN 节点 Cloudflare (端口443) =====
CDN_UUID=你的UUID
CDN_DOMAIN=你的域名
CDN_PORT=443
CDN_WS_PORT=10000
CDN_WS_PATH=/7689b703c6e07790

# ===== x-ui 面板 =====
XUI_PORT=19921
XUI_BASE_PATH=/你的随机路径/
XUI_LISTEN=127.0.0.1

# ===== WARP 代理 (AI 域名解锁) =====
WARP_SOCKS_PORT=40000

# ===== Clash 客户端 =====
CLASH_MIXED_PORT=7897
CLASH_DNS_PORT=1053
